# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  .env.example — copy to .env and fill in your values                        │
# │  See docs/SETUP.md for step-by-step instructions on every section.          │
# └─────────────────────────────────────────────────────────────────────────────┘


# ══════════════════════════════════════════════════════════════════════════════
# SERVER
# ══════════════════════════════════════════════════════════════════════════════

# Deployment environment. One of: development | staging | production
# Controls Redis requirement and other env-gated behaviour. Default: development
APP_ENV=development

# TCP address the HTTP server listens on. Default: :8080
ADDR=:8080

# Human-readable product name shown in emails and page titles. Max 64 characters.
# Surrounding quotes are stripped — APP_NAME="Store" and APP_NAME=Store are equivalent.
APP_NAME="Store"

# Set to true only in production behind a TLS-terminating proxy (Caddy/Nginx).
# Enables the Strict-Transport-Security (HSTS) response header.
HTTPS_ENABLED=false

# Set to true to allow non-Secure cookies in local HTTP development.
# The default (false) keeps cookies Secure-only — the safe production default.
# Must not be true when APP_ENV=production (rejected at startup).
# HTTPS_DISABLED=true

# Set to true to enable maintenance mode, returning 503 for all API requests except health.
# Default: false
MAINTENANCE_MODE=false

# Comma-separated list of trusted proxy CIDRs for X-Forwarded-For resolution.
# Set to 127.0.0.1/32,::1/128 when running behind a local reverse proxy or
# for e2e testing with Newman. Leave empty when running without a proxy.
TRUSTED_PROXIES=127.0.0.1/32,::1/128

# Comma-separated list of CORS-allowed origins. Required.
# Wildcard '*' is forbidden — AllowCredentials requires explicit origins.
ALLOWED_ORIGINS=http://localhost:3000


# ══════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ══════════════════════════════════════════════════════════════════════════════

# Individual fields used by Docker Compose to initialise the Postgres container.
# These must match the credentials in DATABASE_URL below.
DB_NAME=store_dev
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=disable

# Full pgx connection string used by the application. Required.
# Format: postgres://user:pass@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/store_dev?sslmode=disable

# Separate test database — used by integration tests only (never touched in development).
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/store_dev_test?sslmode=disable

# ── Connection pool tuning (optional — defaults shown) ──────────────────────

# Maximum number of open connections in the pool. Default: 20
DB_MAX_CONNS=20

# Minimum number of idle connections kept alive. Default: 2
DB_MIN_CONNS=2

# Maximum time a connection may be reused before being closed. Default: 30m
DB_MAX_CONN_LIFETIME=30m

# Maximum time a connection may sit idle before being closed. Default: 5m
DB_MAX_CONN_IDLE=5m

# How often the pool pings idle connections to verify they are still alive. Default: 1m
DB_HEALTH_CHECK=1m


# ══════════════════════════════════════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════════════════════════════════════

# Password passed to redis-server --requirepass via Docker Compose.
# Must match the password embedded in REDIS_URL below.
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=changeme

# Host port Docker maps to the Redis container. Default: 6380
# (6380 avoids a conflict if you run a local Redis on the default 6379)
REDIS_PORT_DOCKER=6380

# Redis connection string used by the application.
# Required when APP_ENV != development.
# Format: redis://:password@host:port/db
REDIS_URL=redis://:changeme@localhost:6380/0

# Separate Redis DB index for integration tests — keeps test keys isolated.
# Flush between runs: redis-cli -a <password> -p <port> -n 1 FLUSHDB
TEST_REDIS_URL=redis://:changeme@localhost:6380/1


# ══════════════════════════════════════════════════════════════════════════════
# SMTP (Transactional Email)
# ══════════════════════════════════════════════════════════════════════════════

# Mail server hostname. Required.
# Examples: smtp.gmail.com | smtp-mail.outlook.com | smtp.mail.yahoo.com | localhost
SMTP_HOST=smtp.gmail.com

# Mail submission port. Must be one of: 25 (relay), 465 (implicit TLS), 587 (STARTTLS).
# Default: 587
SMTP_PORT=587

# SMTP authentication credentials. Required.
# For Gmail: use an App Password (16 chars, no spaces), not your login password.
SMTP_USERNAME=yourname@gmail.com
SMTP_PASSWORD=your-16-character-app-password

# RFC 5321 envelope sender address shown in the From header. Required.
SMTP_FROM=no-reply@yourdomain.com

# OTP token TTL in minutes. Controls both the email display text and the DB expiry.
# Must be between 1 and 30. The DB schema caps email_verification tokens at 15 min.
# After changing this value, update auth.sql and run `make sqlc`. Default: 15
OTP_VALID_MINUTES=15

# ── Mail queue tuning (optional — defaults shown) ────────────────────────────

# Number of concurrent async mail-delivery goroutines. Default: 4
MAIL_WORKERS=4

# Maximum time allowed for a single mail delivery attempt. Default: 30s
# Format: Go duration string (e.g. 30s, 1m)
MAIL_DELIVERY_TIMEOUT=30s


# ══════════════════════════════════════════════════════════════════════════════
# JWT
# ══════════════════════════════════════════════════════════════════════════════

# Separate HMAC-SHA256 signing keys for access and refresh tokens.
# Rules enforced at startup:
#   - Each must be >= 32 bytes
#   - The two values must NOT be equal
#   - Must have high entropy — all-same-character strings are rejected
# Generate each independently with: openssl rand -hex 32
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# How long an access token stays valid. Keep short — access tokens are not
# server-side revokable. Format: Go duration string. Default: 15m
ACCESS_TOKEN_TTL=15m


# ══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ══════════════════════════════════════════════════════════════════════════════

# AES-256-GCM encryption key for OAuth tokens stored at rest in user_identities.
# Must be exactly 64 valid hex characters (32 bytes decoded).
# Generate with: openssl rand -hex 32. Required.
TOKEN_ENCRYPTION_KEY=

# One-time secret that gates the POST /owner/bootstrap endpoint.
# A caller must supply this value in the request body (bootstrap_secret field)
# AND present a valid JWT access token to be assigned the owner role.
# If unset, every bootstrap request is rejected with 403 at startup.
# Generate with: openssl rand -hex 16
BOOTSTRAP_SECRET=


# ══════════════════════════════════════════════════════════════════════════════
# OAUTH — Shared
# ══════════════════════════════════════════════════════════════════════════════

# Frontend URL the OAuth callback redirects to on a successful login/register/link.
# Session cookies are set on the API domain before the redirect — no query params appended.
OAUTH_SUCCESS_URL=http://localhost:3000/dashboard

# Frontend URL the OAuth callback redirects to on failure.
# The handler appends ?error=<code> so the SPA can display a user-facing message.
OAUTH_ERROR_URL=http://localhost:3000/login


# ══════════════════════════════════════════════════════════════════════════════
# OAUTH — Google
# ══════════════════════════════════════════════════════════════════════════════

# OAuth 2.0 credentials from https://console.cloud.google.com/
# See docs/SETUP.md §8 for step-by-step instructions.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must exactly match one of the Authorised Redirect URIs registered in Google
# Cloud Console. Any mismatch causes a redirect_uri_mismatch error from Google.
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/oauth/google/callback


# ══════════════════════════════════════════════════════════════════════════════
# OAUTH — Telegram
# ══════════════════════════════════════════════════════════════════════════════

# Bot token issued by @BotFather on Telegram.
# Format: <bot_id>:<token>  e.g. 1234567890:AAF_your_bot_token_here
# See docs/SETUP.md §9 for step-by-step instructions including tunnel setup.
TELEGRAM_BOT_TOKEN=


# ══════════════════════════════════════════════════════════════════════════════
# DOCKER
# ══════════════════════════════════════════════════════════════════════════════

# Project name prefix used by Docker Compose for container and volume naming.
# The Postgres container will be named: <COMPOSE_PROJECT_NAME>_postgres
COMPOSE_PROJECT_NAME=store


# ══════════════════════════════════════════════════════════════════════════════
# BITCOIN
# ══════════════════════════════════════════════════════════════════════════════
# All bitcoin settings are ignored unless BTC_ENABLED=true.
# When disabled (the default) the server starts with all bitcoin deps nil.

# Master gate. Set to true only when a Bitcoin Core node is available.
# Default: false
BTC_ENABLED=false

# ── Bitcoin Core RPC ────────────────────────────────────────────────────────

# Bitcoin Core RPC host. Default: 127.0.0.1
BTC_RPC_HOST=127.0.0.1

# Bitcoin Core RPC port. Validated numeric 1–65535.
# Mainnet default: 8332  |  Testnet4 typical: 48332
BTC_RPC_PORT=48332

# RPC credentials set in bitcoin.conf (rpcuser / rpcpassword). Required.
BTC_RPC_USER=your-rpc-user
BTC_RPC_PASS=your-rpc-password

# ── ZMQ endpoints ───────────────────────────────────────────────────────────

# ZMQ endpoint for hashblock notifications. Default: tcp://127.0.0.1:28332
BTC_ZMQ_BLOCK=tcp://127.0.0.1:28332

# ZMQ endpoint for hashtx notifications. Default: tcp://127.0.0.1:28333
BTC_ZMQ_TX=tcp://127.0.0.1:28333

# ZMQ idle timeout in seconds. 0 = use network default. Valid range: 30–3600.
# Default: 0
BTC_ZMQ_IDLE_TIMEOUT=0

# ── Network ─────────────────────────────────────────────────────────────────

# Active Bitcoin network. Must be: testnet4 | mainnet
BTC_NETWORK=testnet4

# ── SSE token ───────────────────────────────────────────────────────────────

# Lifetime of the one-time SSE token in seconds. Range: 1–300. Default: 60
BTC_SSE_TOKEN_TTL=60

# Bind the SSE token to the issuing client IP. Default: true
# Set to false behind a load balancer that rewrites source IPs.
BTC_SSE_TOKEN_BIND_IP=true

# ── Secrets ─────────────────────────────────────────────────────────────────
# Each must be >= 32 bytes.
# Generate with: openssl rand -hex 32

# HMAC key for bitcoin session cookies.
BTC_SESSION_SECRET=your-btc-session-secret-here

# HMAC key for signing SSE one-time tokens. Must differ from BTC_SESSION_SECRET.
BTC_SSE_SIGNING_SECRET=your-btc-sse-signing-secret-here

# HMAC key for pseudonymising jti in sse_token_issuances.
# Must differ from BTC_SESSION_SECRET and BTC_SSE_SIGNING_SECRET.
BTC_SERVER_SECRET=your-btc-server-secret-here

# Daily-rotating HMAC key for source_ip_hash in sse_token_issuances.
BTC_DAILY_ROTATION_KEY=your-btc-daily-rotation-key-here

# HMAC key for audit PII obfuscation (invalid addresses, JTIs).
# Must differ from BTC_SESSION_SECRET, BTC_SSE_SIGNING_SECRET, and BTC_SERVER_SECRET.
BTC_AUDIT_HMAC_KEY=your-btc-audit-hmac-key-here

# ── Capacity limits ─────────────────────────────────────────────────────────

# Maximum concurrent SSE connections per user. Range: 1–10. Default: 3
BTC_MAX_SSE_PER_USER=3

# Maximum concurrent SSE connections across the whole process. Range: 10–10000. Default: 100
BTC_MAX_SSE_PROCESS=100

# Maximum watch addresses per user. Range: 1–1000. Default: 100
BTC_MAX_WATCH_PER_USER=100

# ── Timeouts & tuning ───────────────────────────────────────────────────────

# Block-data cache TTL in seconds. Range: 1–60. Default: 5
BTC_CACHE_TTL=5

# Per-RPC call timeout in seconds. Range: 2–60. Default: 10
BTC_BLOCK_RPC_TIMEOUT_SECONDS=10

# Maximum number of pending mempool transactions tracked. Range: 100–100000. Default: 10000
BTC_PENDING_MEMPOOL_MAX_SIZE=10000

# Maximum age of a pending mempool transaction in days. Range: 1–90. Default: 14
BTC_MEMPOOL_PENDING_MAX_AGE_DAYS=14


# ══════════════════════════════════════════════════════════════════════════════
# E2E TESTS
# ══════════════════════════════════════════════════════════════════════════════

# Gmail address used by the verify-email e2e suite to receive OTP codes.
# Must match SMTP_USERNAME above (the inbox that receives outbound test emails).
# Must also match gmail_test_email in e2e/environment.json.
# The _e2e-db-clean target deletes this user before each run so register never 409s.
E2E_GMAIL_EMAIL=
