# ── Server ────────────────────────────────────────────────────
# Deployment environment. One of: development, staging, production
# Default: development. Controls Redis requirement and other env-gated behaviour.
APP_ENV=development
ADDR=:8080
# Set to true in development to expose GET /docs and GET /docs/openapi.yaml
# Never enable in production — there is no auth on these routes
DOCS_ENABLED=false
APP_NAME="your app name"
# Set to true only in production behind a proxy (Caddy/Nginx)
HTTPS_ENABLED=false
# Set HTTPS_DISABLED=true to allow non-secure cookies in local development.
# The default is secure-only (omitting this var keeps cookies Secure).
# HTTPS_DISABLED=true
# Trusted Proxy CIDRs (e.g., 127.0.0.1/32)
# Set to 127.0.0.1/32 for e2e testing — Newman connects from loopback and the
# collections inject unique X-Forwarded-For IPs so non-RL folders never exhaust
# the rate-limit bucket. Leave empty when running without a reverse proxy.
TRUSTED_PROXIES=127.0.0.1/32,::1/128
# Comma-separated list of allowed CORS origins.
# Wildcard '*' is FORBIDDEN — AllowCredentials requires explicit origins.
# List every origin the SPA is served from, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Number of async mail-delivery goroutines. Default: 4
MAIL_WORKERS=4
# Maximum time allowed for a single mail delivery attempt. Default: 30s
# Format: Go duration string (e.g. 30s, 1m).
MAIL_DELIVERY_TIMEOUT=30s

# ── Database ──────────────────────────────────────────────────
DB_NAME="your database name"
DB_USER="your database username"
DB_PASSWORD="your database password"
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=disable

# The app expects a full connection string
# Format: postgres://user:pass@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/ecommerce_dev?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/ecommerce_dev_test?sslmode=disable

# Connection Pool Settings
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE=5m
DB_HEALTH_CHECK=1m

# ── SMTP Mailer ───────────────────────────────────────────────
# Providers: smtp.gmail.com | smtp-mail.outlook.com | smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=name@gmail.com
# Use an "App Password", not your login password.
# Gmail displays App Passwords with spaces (e.g. "abcd efgh ijkl mnop") — paste
# the 16 characters WITHOUT spaces and WITHOUT quotes: abcdefghijklmnop
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM=no-reply@yourdomain.com
# OTP token TTL in minutes. Controls both the email display text and the DB expiry.
# Must be between 1 and 30 (the chk_ott_ev_ttl_max constraint cap).
# IMPORTANT: changing this also requires updating the INTERVAL in auth.sql and running `make sqlc`.
# Default: 15
OTP_VALID_MINUTES=15

# ── JWT ───────────────────────────────────────────────────────
# Separate HMAC-SHA256 signing keys for access and refresh tokens.
# Using distinct secrets provides defense-in-depth: a compromised access-token
# key cannot be used to forge refresh tokens, and each can be rotated independently.
# Rules:
#   - Each must be >= 32 bytes (enforced at startup)
#   - The two values MUST NOT be equal
#   - Must have high entropy — all-same-character strings are rejected at startup
# Generate each value independently with:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# How long an access token stays valid. Keep short — not server-side revokable.
# Format: Go duration string (e.g. 15m, 1h). Default: 15m
ACCESS_TOKEN_TTL=15m

# ── Redis ────────────────────────────────────────────────────
# Redis runs as a Docker service (see docker-compose.yml).
# REDIS_PASSWORD is passed to redis-server --requirepass and must match REDIS_URL.
# Generate a strong password with: openssl rand -hex 32
# REDIS_URL is required when APP_ENV != development.
# Format: redis://:password@host:port/db
REDIS_PASSWORD=changeme
REDIS_PORT_DOCKER=6380
REDIS_URL=redis://:changeme@localhost:6380/0
# Integration tests use DB index 1 — keeps test keys isolated from dev data.
# Flush between runs: redis-cli -a <password> -p <port> -n 1 FLUSHDB
TEST_REDIS_URL=redis://:changeme@localhost:6380/1

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Docker envs, your container name will be container_name: ${COMPOSE_PROJECT_NAME:-app}_postgres
COMPOSE_PROJECT_NAME="your app COMPOSE_PROJECT_NAME"

# ── E2E Tests ─────────────────────────────────────────────────
# Gmail address used by the verify-email e2e suite.
# Must match SMTP_USERNAME above (the inbox that receives OTP emails) and
# gmail_test_email in e2e/environment.json.
# _e2e-db-clean deletes this user before each run so setup/register never 409s.
E2E_GMAIL_EMAIL=
