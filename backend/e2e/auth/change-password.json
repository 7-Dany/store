{
  "info": {
    "_postman_id": "auth-change-password-e2e",
    "name": "Auth \u2013 Change Password (PATCH /api/v1/auth/password)",
    "description": "E2E tests for PATCH /api/v1/auth/password (requires JWT).\n\nFolder execution order (orchestrated by make e2e-change-password):\n  1. setup             \u2014 register gmail_test_email, fetch verification OTP from Gmail, verify email\n  2. happy-path        \u2014 login (capture pre-change access token + refresh cookie) \u2192\n                         correct old_password + valid new_password \u2192 200,\n                         refresh cookie cleared in response (MaxAge negative),\n                         GET /me with pre-change access token \u2192 401 (JTI blocklisted),\n                         login with old password \u2192 401, login with new password \u2192 200\n  3. failures          \u2014 wrong old_password \u2192 401 (attempt 1), same password \u2192 422,\n                         3 more wrong attempts \u2192 401 (attempts 2-4),\n                         5th wrong attempt \u2192 429 too_many_attempts,\n                         reset counter via correct change, subsequent wrong attempt \u2192 401 not 429,\n                         new_password too short \u2192 422, missing old_password \u2192 422,\n                         missing new_password \u2192 422\n  4. auth-failures     \u2014 missing Authorization header \u2192 401, tampered token signature \u2192 401\n  5. validation        \u2014 body > 1 MiB \u2192 413, malformed JSON \u2192 400\n  6. rate-limiting-cpw \u2014 cpw:ip: bucket (burst=5): 5 warmups \u2192 6th \u2192 429\n\nAll test users use @e2e.test emails (or gmail_test_email) so `make _e2e-db-clean` can wipe them.\nRun `make _e2e-db-clean` and `make _e2e-kv-clean` before this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const n = (pm.collectionVariables.get('_req_seq') | 0) + 1;",
          "pm.collectionVariables.set('_req_seq', n);",
          "const ip = '10.' + ((n>>16)&0xff) + '.' + ((n>>8)&0xff) + '.' + (n&0xff);",
          "pm.collectionVariables.set('_xff', ip);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "setup",
      "description": "Registers the gmail_test_email user, fetches the verification OTP from Gmail, and verifies the email.",
      "item": [
        {
          "name": "POST /register \u2192 201 (setup user)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = pm.environment.get('gmail_test_email');",
                  "if (!email) { console.error('[ERROR] gmail_test_email not set in environment.'); }",
                  "pm.collectionVariables.set('cpw_email', email);",
                  "pm.collectionVariables.set('cpw_password', 'P@ssw0rd1!');",
                  "pm.collectionVariables.set('cpw_new_password', 'NewCpwP@ss2!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const token = pm.variables.get('gmail_access_token');",
                  "if (!token) { console.warn('[WARN] gmail_access_token not set \u2014 skipping Gmail fetch'); return; }",
                  "console.log('[INFO] Waiting 8 s for verification email...');",
                  "const start = Date.now(); while (Date.now() - start < 8000) {}",
                  "const query = encodeURIComponent('subject:\"Verify your\" newer_than:1h');",
                  "pm.sendRequest({ url: 'https://gmail.googleapis.com/gmail/v1/users/me/messages?q=' + query + '&maxResults=3', method: 'GET', header: { Authorization: 'Bearer ' + token } }, (err, res) => {",
                  "    if (err || res.code === 401) { console.error('[ERROR] Gmail list failed'); return; }",
                  "    const msgs = res.json().messages;",
                  "    if (!msgs || !msgs.length) { console.warn('[WARN] No verification email found.'); return; }",
                  "    pm.sendRequest({ url: 'https://gmail.googleapis.com/gmail/v1/users/me/messages/' + msgs[0].id + '?format=full', method: 'GET', header: { Authorization: 'Bearer ' + token } }, (err2, res2) => {",
                  "        if (err2) { console.error('[ERROR] Gmail fetch failed'); return; }",
                  "        const msg = res2.json(); let body = '';",
                  "        const parts = msg.payload && msg.payload.parts;",
                  "        if (parts && parts.length) { const p = parts.find(x => x.mimeType === 'text/plain') || parts.find(x => x.mimeType === 'text/html'); if (p && p.body && p.body.data) body = atob(p.body.data.replace(/-/g, '+').replace(/_/g, '/')); }",
                  "        else if (msg.payload && msg.payload.body && msg.payload.body.data) { body = atob(msg.payload.body.data.replace(/-/g, '+').replace(/_/g, '/')); }",
                  "        if (!body) { console.warn('[WARN] Could not decode email body.'); return; }",
                  "        const match = body.match(/(?<!#)\\b(\\d{6})\\b/);",
                  "        if (!match) { console.warn('[WARN] No 6-digit OTP found.'); return; }",
                  "        pm.collectionVariables.set('cpw_code', match[1]);",
                  "        console.log('[INFO] OTP stored in cpw_code:', match[1]);",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"display_name\": \"CpwHappy\", \"email\": \"{{cpw_email}}\", \"password\": \"{{cpw_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "POST /verification \u2192 200 (consume OTP)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const code = pm.collectionVariables.get('cpw_code');",
                  "if (!code) { console.error('[ERROR] cpw_code is empty \u2014 Gmail fetch did not complete.'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('message includes \"verified\"', () => pm.expect(pm.response.json().message).to.include('verified'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{cpw_email}}\", \"code\": \"{{cpw_code}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verification",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verification"]
            }
          }
        }
      ]
    },
    {
      "name": "happy-path",
      "description": "Login, change password, verify old token blocklisted, old password rejected, new password works.",
      "item": [
        {
          "name": "POST /login \u2192 200 (capture pre-change token + refresh cookie)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('access_token present', () => pm.expect(body.access_token).to.be.a('string').and.not.empty);",
                "pm.collectionVariables.set('cpw_pre_change_token', body.access_token);",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "const match = sc.match(/refresh_token=([^;]+)/);",
                "if (match) { pm.collectionVariables.set('cpw_refresh_token', match[1]); }"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\": \"{{cpw_email}}\", \"password\": \"{{cpw_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "PATCH /password \u2192 200 (correct old + valid new)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', () => pm.response.to.have.status(200));",
                "pm.test('message present', () => pm.expect(pm.response.json().message).to.be.a('string').and.not.empty);",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('refresh cookie cleared (MaxAge \u2264 0)', () => {",
                "    if (!sc) return;",
                "    const m = sc.match(/Max-Age=(-?\\d+)/);",
                "    if (m) pm.expect(parseInt(m[1], 10)).to.be.at.most(0);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{cpw_pre_change_token}}" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"old_password\": \"{{cpw_password}}\", \"new_password\": \"{{cpw_new_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "password"]
            }
          }
        },
