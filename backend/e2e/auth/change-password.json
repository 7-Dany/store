              "raw": "{\"identifier\": \"{{cpw_email}}\", \"password\": \"{{cpw_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "POST /login with NEW password \u2192 200",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200 (new password works)', () => pm.response.to.have.status(200));",
                "pm.test('access_token present', () => pm.expect(pm.response.json().access_token).to.be.a('string').and.not.empty);",
                "pm.collectionVariables.set('cpw_new_token', pm.response.json().access_token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\": \"{{cpw_email}}\", \"password\": \"{{cpw_new_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
