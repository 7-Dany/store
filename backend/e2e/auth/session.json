          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200 (device D logged in)', () => pm.response.to.have.status(200));",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "const match = sc.match(/refresh_token=([^;]+)/);",
                "if (match) { pm.collectionVariables.set('sss_reuse_refresh_d', match[1]); }"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
