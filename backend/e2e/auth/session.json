            "method": "POST",
            "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }, { "key": "Cookie", "value": "refresh_token={{sss_reuse_refresh_d}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] }
          }
        },
