    {
      "name": "rate-limiting",
      "description": "Verifies rfsh:ip: (burst=5, Retry-After=180s) and lgout:ip: (burst=5, Retry-After=12s) limiters.",
      "event": [{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": ["pm.collectionVariables.set('_xff', '127.0.0.1');"] } }],
      "item": [
        { "name": "refresh warmup 1/5", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('not rate-limited (rfsh slot 1)', () => pm.expect(pm.response.code).to.not.eql(429));"] } }], "request": { "method": "POST", "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }], "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] } } },
        { "name": "refresh warmup 2/5", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('not rate-limited (rfsh slot 2)', () => pm.expect(pm.response.code).to.not.eql(429));"] } }], "request": { "method": "POST", "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }], "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] } } },
        { "name": "refresh warmup 3/5", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('not rate-limited (rfsh slot 3)', () => pm.expect(pm.response.code).to.not.eql(429));"] } }], "request": { "method": "POST", "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }], "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] } } },
        { "name": "refresh warmup 4/5", "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('not rate-limited (rfsh slot 4)', () => pm.expect(pm.response.code).to.not.eql(429));"] } }], "request": { "method": "POST", "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }], "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] } } },
