{
  "info": {
    "_postman_id": "auth-session-e2e",
    "name": "Auth \u2013 Session (POST /api/v1/auth/refresh + POST /api/v1/auth/logout)",
    "description": "E2E tests for POST /api/v1/auth/refresh and POST /api/v1/auth/logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const n = (pm.collectionVariables.get('_req_seq') | 0) + 1;",
          "pm.collectionVariables.set('_req_seq', n);",
          "const ip = '10.' + ((n>>16)&0xff) + '.' + ((n>>8)&0xff) + '.' + (n&0xff);",
          "pm.collectionVariables.set('_xff', ip);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "happy-path",
      "description": "Registers the gmail_test_email user, fetches the OTP from Gmail, verifies the email, and logs in on two separate devices (A and B).",
      "item": [
        {
          "name": "POST /register \u2192 201 (setup user)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = pm.environment.get('gmail_test_email');",
                  "if (!email) { console.error('[ERROR] gmail_test_email not set in environment.'); }",
                  "pm.collectionVariables.set('sss_email', email);",
                  "pm.collectionVariables.set('sss_password', 'P@ssw0rd1!');",
                  "pm.collectionVariables.set('sss_reg_ts', Math.floor(Date.now() / 1000));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const token = pm.variables.get('gmail_access_token');",
                  "if (!token) { console.warn('[WARN] gmail_access_token not set'); return; }",
                  "console.log('[INFO] Waiting 8 s for verification email...');",
                  "const start = Date.now(); while (Date.now() - start < 8000) {}",
                  "const regTs = pm.collectionVariables.get('sss_reg_ts') || Math.floor((Date.now() - 60000) / 1000);",
                  "const query = encodeURIComponent('subject:\"Verify your\" after:' + regTs);",
                  "pm.sendRequest({ url: 'https://gmail.googleapis.com/gmail/v1/users/me/messages?q=' + query + '&maxResults=3', method: 'GET', header: { Authorization: 'Bearer ' + token } }, (err, res) => {",
                  "    if (err || res.code === 401) { console.error('[ERROR] Gmail list failed'); return; }",
                  "    const msgs = res.json().messages;",
                  "    if (!msgs || !msgs.length) { console.warn('[WARN] No matching email found.'); return; }",
                  "    pm.sendRequest({ url: 'https://gmail.googleapis.com/gmail/v1/users/me/messages/' + msgs[0].id + '?format=full', method: 'GET', header: { Authorization: 'Bearer ' + token } }, (err2, res2) => {",
                  "        if (err2) { console.error('[ERROR] Gmail fetch failed'); return; }",
                  "        const msg = res2.json(); let body = '';",
                  "        const parts = msg.payload && msg.payload.parts;",
                  "        if (parts && parts.length) { const p = parts.find(x => x.mimeType === 'text/plain') || parts.find(x => x.mimeType === 'text/html'); if (p && p.body && p.body.data) body = atob(p.body.data.replace(/-/g, '+').replace(/_/g, '/')); }",
                  "        else if (msg.payload && msg.payload.body && msg.payload.body.data) { body = atob(msg.payload.body.data.replace(/-/g, '+').replace(/_/g, '/')); }",
                  "        if (!body) { console.warn('[WARN] Could not decode email body.'); return; }",
                  "        const match = body.match(/(?<!#)\\b(\\d{6})\\b/);",
                  "        if (!match) { console.warn('[WARN] No 6-digit OTP found.'); return; }",
                  "        pm.collectionVariables.set('sss_code', match[1]);",
                  "        console.log('[INFO] OTP stored in sss_code:', match[1]);",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
            "body": { "mode": "raw", "raw": "{\"display_name\": \"SssHappy\", \"email\": \"{{sss_email}}\", \"password\": \"{{sss_password}}\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] }
          }
        },
        {
          "name": "POST /verification \u2192 200 (consume OTP)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const code = pm.collectionVariables.get('sss_code');",
                  "if (!code) { console.error('[ERROR] sss_code is empty \u2014 Gmail fetch did not complete.'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('message includes \"verified\"', () => pm.expect(pm.response.json().message).to.include('verified'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
            "body": { "mode": "raw", "raw": "{\"email\": \"{{sss_email}}\", \"code\": \"{{sss_code}}\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/v1/auth/verification", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "verification"] }
          }
        },
        {
          "name": "POST /login device A \u2192 200 (store tokens)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('access_token present', () => pm.expect(body.access_token).to.be.a('string').and.not.empty);",
                "pm.collectionVariables.set('sss_access_token_a', body.access_token);",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('refresh_token cookie present', () => pm.expect(sc).to.include('refresh_token='));",
                "const match = sc.match(/refresh_token=([^;]+)/);",
                "if (match) { pm.collectionVariables.set('sss_refresh_token_a', match[1]); } else { console.error('[ERROR] Could not extract refresh_token.'); }"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
            "body": { "mode": "raw", "raw": "{\"identifier\": \"{{sss_email}}\", \"password\": \"{{sss_password}}\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "POST /login device B \u2192 200 (sibling session, separate family_id)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('sss_access_token_b', body.access_token);",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "const match = sc.match(/refresh_token=([^;]+)/);",
                "if (match) { pm.collectionVariables.set('sss_refresh_token_b', match[1]); }"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
            "body": { "mode": "raw", "raw": "{\"identifier\": \"{{sss_email}}\", \"password\": \"{{sss_password}}\"}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "POST /refresh device A \u2192 200 (assert cookie attrs, store new tokens)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('access_token present in body', () => { pm.expect(body).to.have.property('access_token'); pm.expect(body.access_token).to.be.a('string').and.not.empty; });",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('new refresh_token cookie present', () => pm.expect(sc).to.include('refresh_token='));",
                "pm.test('HttpOnly', () => pm.expect(sc.toLowerCase()).to.include('httponly'));",
                "pm.test('Path=/api/v1/auth', () => pm.expect(sc).to.include('Path=/api/v1/auth'));",
                "pm.test('SameSite=Strict', () => pm.expect(sc).to.include('SameSite=Strict'));",
                "pm.test('positive Max-Age', () => { const m = sc.match(/Max-Age=(\\d+)/); pm.expect(m).to.not.be.null; pm.expect(parseInt(m[1], 10)).to.be.above(0); });",
                "pm.collectionVariables.set('sss_old_refresh_token_a', pm.collectionVariables.get('sss_refresh_token_a'));",
                "pm.collectionVariables.set('sss_new_access_token_a', body.access_token);",
                "const match = sc.match(/refresh_token=([^;]+)/);",
                "if (match) { pm.collectionVariables.set('sss_new_refresh_token_a', match[1]); }"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }, { "key": "Cookie", "value": "refresh_token={{sss_refresh_token_a}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] }
          }
        },
        {
          "name": "POST /logout device A \u2192 204 (cookie cleared in Set-Cookie)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 204', () => pm.response.to.have.status(204));",
                "pm.test('response body is empty', () => pm.expect(pm.response.text()).to.be.empty);",
                "const sc = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('refresh_token cookie cleared (Max-Age<=0)', () => { pm.expect(sc).to.include('refresh_token='); const m = sc.match(/Max-Age=(-?\\d+)/); pm.expect(m).to.not.be.null; pm.expect(parseInt(m[1], 10)).to.be.at.most(0); });"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{sss_new_access_token_a}}" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }, { "key": "Cookie", "value": "refresh_token={{sss_new_refresh_token_a}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        },
        {
          "name": "GET /me with old access_token_a \u2192 401 (blocklisted by KV store)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 401 (access token blocklisted after logout)', () => pm.response.to.have.status(401));",
                "pm.test('code indicates token is invalid or revoked', () => { pm.expect(['invalid_token', 'token_revoked', 'unauthorized']).to.include(pm.response.json().code); });"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sss_new_access_token_a}}" }, { "key": "X-Forwarded-For", "value": "{{_xff}}" }],
            "url": { "raw": "{{base_url}}/api/v1/profile/me", "host": ["{{base_url}}"], "path": ["api", "v1", "profile", "me"] }
          }
        },
        {
          "name": "POST /refresh device B \u2192 200 (sibling session unaffected by device A logout)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status is 200 (device B refresh unaffected by device A logout)', () => pm.response.to.have.status(200));",
                "pm.test('access_token present for device B', () => pm.expect(pm.response.json().access_token).to.be.a('string').and.not.empty);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "X-Forwarded-For", "value": "{{_xff}}" }, { "key": "Cookie", "value": "refresh_token={{sss_refresh_token_b}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] }
          }
        }
      ]
    },
