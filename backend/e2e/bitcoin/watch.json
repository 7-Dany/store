    {
      "name": "happy-path",
      "description": "Successful watch registration cases. Uses watch_access_token from setup.\nEnsure Redis is clean (`make _e2e-kv-clean`) before running so the per-user\ncount cap and 7-day window start fresh.",
      "item": [
        {
          "name": "single valid address (P2WPKH bech32) \u2192 200 watching echoes address",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('watching array is present', () => pm.expect(body).to.have.property('watching').that.is.an('array'));",
                  "pm.test('watching contains exactly 1 address', () => pm.expect(body.watching).to.have.lengthOf(1));",
                  "// bech32 addresses are lowercased by ValidateAndNormalise.",
                  "pm.test('watching[0] matches submitted address (lowercased)', () => {",
                  "    pm.expect(body.watching[0]).to.eql('tb1qw508d6qejxtdg4y5r3zarvary0c5xw7kxpjzsx');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "Authorization",
                "value": "Bearer {{watch_access_token}}"
              },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"network\": \"{{btc_network}}\", \"addresses\": [\"tb1qw508d6qejxtdg4y5r3zarvary0c5xw7kxpjzsx\"]}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/bitcoin/watch",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "bitcoin", "watch"]
            }
          }
        },
        {
          "name": "two valid addresses (P2WPKH + P2PKH legacy) \u2192 200 watching echoes both",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('watching array is present', () => pm.expect(body).to.have.property('watching').that.is.an('array'));",
                  "pm.test('watching contains exactly 2 addresses', () => pm.expect(body.watching).to.have.lengthOf(2));",
                  "// bech32 is lowercased; base58check keeps original casing.",
                  "pm.test('watching includes the bech32 address (lowercased)', () => {",
                  "    pm.expect(body.watching).to.include('tb1qw508d6qejxtdg4y5r3zarvary0c5xw7kxpjzsx');",
                  "});",
                  "pm.test('watching includes the P2PKH address', () => {",
