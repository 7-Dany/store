                "type": "text/javascript",
                "exec": [
                  "// Build an array of 20 distinct-looking addresses using the bech32 test vector.",
                  "// The handler allows exactly 20; 21 was rejected in the validation folder.",
                  "// NOTE: These are all the same address; SADD treats them as 1 unique member.",
                  "// The guard check (len > 20) happens before uniqueness is considered, so 20",
                  "// identical entries still passes the length guard and is a valid e2e signal.",
                  "const addrs = [];",
                  "for (let i = 0; i < 20; i++) {",
                  "    addrs.push('tb1qw508d6qejxtdg4y5r3zarvary0c5xw7kxpjzsx');",
                  "}",
                  "pm.collectionVariables.set('_max_addrs', JSON.stringify(addrs));"
                ]
              }
            },
