{
  "info": {
    "_postman_id": "health-e2e",
    "name": "Health (GET /health)",
    "description": "E2E tests for GET /health.\n\nFolder execution order (orchestrated by make e2e-health):\n  1. smoke          — 200 response shape + security headers\n  2. rate-limiting  — 429 after bucket exhaustion (Makefile flushes Redis before this folder)\n\nRate-limiter config (routes.go): burst=3, rate=3/min per IP.\nThe rate-limiting folder sends 3 warmup GETs to drain the bucket, then the 4th must 429.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "smoke",
      "item": [
        {
          "name": "GET /health → 200 {status:ok}",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('body.status is ok', () => pm.expect(b.status).to.eql('ok'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },

        {
          "name": "GET /health → security headers present",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('X-Content-Type-Options: nosniff', () =>",
                  "  pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff')",
                  ");",
                  "pm.test('X-Frame-Options: DENY', () =>",
                  "  pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY')",
                  ");"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },

    {
      "name": "rate-limiting",
      "description": "Burst=3 (NewIPRateLimiter rate=3/60 burst=3). Send 3 warmups to drain the bucket, then the 4th must 429. Requests fire with --delay-request 1 so refill (0.05 tok/s) is negligible between back-to-back calls.",
      "item": [
        {
          "name": "warmup 1/3 — consume slot (→ not 429)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('not rate-limited yet (slot 1)', () => pm.expect(pm.response.code).to.not.eql(429));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },

        {
          "name": "warmup 2/3 — consume slot (→ not 429)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('not rate-limited yet (slot 2)', () => pm.expect(pm.response.code).to.not.eql(429));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },

        {
          "name": "warmup 3/3 — consume slot (→ not 429, last allowed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('not rate-limited yet (slot 3 - last allowed)', () => pm.expect(pm.response.code).to.not.eql(429));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },

        {
          "name": "4th request → 429 (bucket exhausted)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 429', () => pm.response.to.have.status(429));",
                  "const b = pm.response.json();",
                  "pm.test('code is rate_limited', () => pm.expect(b.code).to.eql('rate_limited'));",
                  "pm.test('Retry-After header present', () => pm.expect(pm.response.headers.get('Retry-After')).to.eql('20'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ]
}
