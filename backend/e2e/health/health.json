          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('not rate-limited yet (slot 7)', () => pm.expect(pm.response.code).to.not.eql(429));"]}}],
          "request": {"method": "GET", "header": [], "url": {"raw": "{{base_url}}/api/v1/health", "host": ["{{base_url}}"], "path": ["api", "v1", "health"]}}
