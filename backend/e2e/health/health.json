        },
        {
          "name": "warmup 10/10 — consume slot (→ not 429, last allowed)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('not rate-limited yet (slot 10 - last allowed)', () => pm.expect(pm.response.code).to.not.eql(429));"]}}],
          "request": {"method": "GET", "header": [], "url": {"raw": "{{base_url}}/api/v1/health", "host": ["{{base_url}}"], "path": ["api", "v1", "health"]}}
        },

        {
          "name": "11th request → 429 (bucket exhausted)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 429', () => pm.response.to.have.status(429));",
                  "const b = pm.response.json();",
                  "pm.test('code is too_many_requests', () => pm.expect(b.code).to.eql('too_many_requests'));",
                  "pm.test('Retry-After header is 2', () => pm.expect(pm.response.headers.get('Retry-After')).to.eql('2'));"
                ]
              }
            }
          ],
          "request": {"method": "GET", "header": [], "url": {"raw": "{{base_url}}/api/v1/health", "host": ["{{base_url}}"], "path": ["api", "v1", "health"]}}
        }
