    {
      "name": "rate-limiting",
      "description": "rsess:ip: limiter — burst=3, rate=3/15min (≈0.0033 t/s).\nWarmup requests use a non-existent UUID (00000000-…-0001): JWT auth passes,\nlimiter fires (slot consumed), handler returns 404. 4th → 429, Retry-After=300.\n\nRequires Redis flushed (make _e2e-kv-clean) before this folder.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": ["pm.collectionVariables.set('_xff', '127.0.0.1');"]
          }
        }
      ],
      "item": [
        {
          "name": "warmup 1/3 — consume rsess:ip: slot (→ not 429)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('not rate-limited yet (rsess:ip: slot 1/3)', () => pm.expect(pm.response.code).to.not.eql(429));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{rev_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/profile/sessions/00000000-0000-0000-0000-000000000001",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "v1",
                "profile",
                "sessions",
                "00000000-0000-0000-0000-000000000001"
              ]
            }
          }
        },
        {
          "name": "warmup 2/3 — consume rsess:ip: slot (→ not 429)",
          "event": [
            {
