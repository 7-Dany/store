                "type": "text/javascript",
                "exec": [
                  "pm.test('not rate-limited yet (rsess:ip: slot 3/3)', () => pm.expect(pm.response.code).to.not.eql(429));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{rev_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
