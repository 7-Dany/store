        },
        {
          "name": "GET /api/v1/profile/sessions: 11th request → 429 (psess:ip: exhausted)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 429', () => pm.response.to.have.status(429));",
                  "pm.test('code is rate_limited', () => pm.expect(pm.response.json().code).to.eql('rate_limited'));",
                  "pm.test('Retry-After is 6 (ceil(1/(10/60))=6 s)', () => {",
                  "    pm.expect(pm.response.headers.get('Retry-After')).to.eql('6');",
                  "});"
                ]
              }
            }
