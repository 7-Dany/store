          "request": {"method": "GET","header": [{"key": "Authorization","value": "Bearer {{sess_access_token}}"},{"key": "X-Forwarded-For","value": "{{_xff}}"}],"url": {"raw": "{{base_url}}/api/v1/profile/sessions","host": ["{{base_url}}"],"path": ["api","v1","profile","sessions"]}}
        },
