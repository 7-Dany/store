    {
      "name": "validation",
      "description": "Body-size and malformed-JSON cases for POST /set-password.\nBoth use spw_access_token since the JWTAuth middleware fires before body decoding.\n\nNOTE: These 2 requests consume the last 2 of the 5 spw:usr: bucket slots for\nspw_access_token (failures consumed the first 3). The rate-limiting-spw folder\nuses spw_rl_access_token (a separate user) to avoid starting with an empty bucket.",
      "item": [
        {
          "name": "body > 1 MiB → 413",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Pad the body past the 1 MiB MaxBytesReader limit set in handler.SetPassword.",
                  "// http.MaxBytesReader fires during json.Decoder.Decode → respond.DecodeJSON maps this to 413.",
                  "const pad = 'x'.repeat(1024 * 1024 + 1);",
                  "pm.request.body.update({",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({ new_password: 'ValidP@ss1!', _pad: pad })",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 413', () => pm.response.to.have.status(413));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "Authorization",
                "value": "Bearer {{spw_access_token}}"
