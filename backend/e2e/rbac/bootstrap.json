    {
      "name": "secret-guard",
      "description": "Verifies the BOOTSTRAP_SECRET constant-time comparison. A valid JWT is present, the body is well-formed, but bootstrap_secret does not match the server's BOOTSTRAP_SECRET. Must return 403 forbidden before any service or DB call is made.",
      "item": [
        {
          "name": "wrong bootstrap_secret → 403 forbidden",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// subtle.ConstantTimeCompare fails → handler returns 403 before reaching the service.",
                  "// No DB state changes — this request is entirely safe to repeat.",
                  "pm.test('status is 403', () => pm.response.to.have.status(403));",
                  "pm.test('code is forbidden', () => pm.expect(pm.response.json().code).to.eql('forbidden'));",
                  "pm.test('no role_name or granted_at in body', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.not.have.property('role_name');",
                  "    pm.expect(body).to.not.have.property('granted_at');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              {
                "key": "Authorization",
                "value": "Bearer {{bstrp_access_token}}"
              },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"bootstrap_secret\": \"this-is-the-wrong-secret\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/owner/bootstrap",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "owner", "bootstrap"]
            }
          }
        }
      ]
    },
    {
      "name": "happy-path",
      "description": "Uses the verified + authenticated account created by setup (bstrp_access_token from POST /login, bstrp_happy_id from GET /me). Sends the correct bootstrap_secret from the environment. Asserts 201 with user_id matching the JWT caller, role_name=owner, and granted_at. This call consumes the one-time bootstrap slot.",
      "item": [
        {
          "name": "POST /bootstrap valid JWT + correct secret → 201 owner assigned",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('bstrp_access_token');",
                  "if (!token) {",
                  "    console.error('[ERROR] bstrp_access_token not set — setup/POST /login did not capture the token.');",
                  "}",
                  "const secret = pm.environment.get('bootstrap_secret');",
                  "if (!secret) {",
                  "    console.error('[ERROR] bootstrap_secret not set in environment — add it to environment.json.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "// user_id must be echoed back and must match the authenticated caller.",
                  "pm.test('user_id matches the JWT caller (bstrp_happy_id)', () => {",
                  "    const expected = pm.collectionVariables.get('bstrp_happy_id');",
                  "    pm.expect(body.user_id).to.eql(expected);",
                  "});",
                  "",
                  "// role_name must be 'owner'.",
                  "pm.test('role_name is owner', () => {",
                  "    pm.expect(body.role_name).to.eql('owner');",
                  "});",
                  "",
                  "// granted_at must be an ISO 8601 timestamp.",
                  "pm.test('granted_at is a parseable date', () => {",
                  "    pm.expect(body).to.have.property('granted_at');",
