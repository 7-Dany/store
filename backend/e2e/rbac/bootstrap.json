            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\": \"{{bstrp_happy_email}}\", \"password\": \"{{bstrp_happy_password}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "GET /me → 200 (capture user_id for assertions)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('id field present and UUID format', () => {",
                  "    pm.expect(body.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "});",
                  "pm.collectionVariables.set('bstrp_happy_id', body.id);",
                  "console.log('[INFO] Captured user_id for assertions:', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bstrp_access_token}}"
              },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/profile/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "profile", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "auth-guard",
      "description": "Verifies that the JWT middleware rejects unauthenticated callers before any body or service logic is reached. No Authorization header is sent. Must return 401 regardless of body content.",
      "item": [
        {
          "name": "no Authorization header → 401 unauthorized",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// JWTAuth middleware fires first — no token means 401 before body is read.",
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('code is unauthorized', () => pm.expect(pm.response.json().code).to.eql('missing_token'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Forwarded-For", "value": "{{_xff}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"bootstrap_secret\": \"{{bootstrap_secret}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/owner/bootstrap",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "owner", "bootstrap"]
            }
          }
        }
      ]
    },
