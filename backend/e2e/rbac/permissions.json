                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('code is missing_token', () => pm.expect(pm.response.json().code).to.eql('missing_token'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions/groups",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions", "groups"]
            }
          }
        }
      ]
    },
    {
      "name": "rbac-guard",
      "description": "Verifies that RBAC.Require(rbac:read) rejects a valid JWT belonging to a plain user with no rbac:read permission. The JWT is valid (from setup/login) but the user has not yet been bootstrapped as owner. Must return 403 before the handler is called. owner-bootstrap runs after this folder.",
      "item": [
        {
          "name": "GET /permissions \u2014 valid JWT, no rbac:read \u2192 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// JWTAuth passes (valid token). RBAC.Require(rbac:read) fires next \u2014",
                  "// user has no owner role and no explicit rbac:read grant \u2192 403.",
                  "pm.test('status is 403', () => pm.response.to.have.status(403));",
                  "pm.test('code is forbidden', () => pm.expect(pm.response.json().code).to.eql('forbidden'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{perms_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions"]
            }
          }
        },
        {
          "name": "GET /permissions/groups \u2014 valid JWT, no rbac:read \u2192 403",
          "event": [
            {
              "listen": "test",
              "script": {
