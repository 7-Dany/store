    {
      "name": "owner-bootstrap",
      "description": "Promotes the setup user to owner by calling POST /owner/bootstrap with the correct bootstrap_secret. The owner role carries all permissions including rbac:read. RBAC.Require reads the DB on every request \u2014 no re-login is needed; the existing perms_access_token is sufficient for subsequent happy-path requests.",
      "item": [
        {
          "name": "POST /owner/bootstrap \u2192 201 (grant owner role to perms user)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('perms_access_token');",
                  "if (!token) {",
                  "    console.error('[ERROR] perms_access_token not set \u2014 setup/POST /login did not complete.');",
                  "}",
                  "const secret = pm.environment.get('bootstrap_secret');",
                  "if (!secret) {",
                  "    console.error('[ERROR] bootstrap_secret not set in environment \u2014 add it to environment.json.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('role_name is owner', () => pm.expect(pm.response.json().role_name).to.eql('owner'));",
                  "console.log('[INFO] perms user is now owner \u2014 RBAC.Require(rbac:read) will pass on subsequent requests.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{perms_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"secret\": \"{{bootstrap_secret}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/owner/assign",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "owner", "assign"]
            }
          }
        }
      ]
    },
    {
      "name": "happy-path",
      "description": "Authenticated as owner (rbac:read granted by owner-bootstrap). Both routes return 200 with the correct top-level key and array shape. Asserts that seeded permissions and groups are present. Each permission must have id, canonical_name, resource_type, name, and a capabilities object with scope_policy and access_types. Each group must have id, name, display_order, is_visible, and a members array where each member carries the same fields plus capabilities.",
      "item": [
        {
          "name": "GET /permissions \u2192 200 \u2014 permissions array with required fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('top-level key is permissions array', () => {",
                  "    pm.expect(body.permissions).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('permissions list is non-empty (seed data present)', () => {",
                  "    pm.expect(body.permissions.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('each permission has id, canonical_name, resource_type, name', () => {",
                  "    body.permissions.forEach((p, i) => {",
                  "        pm.expect(p, `permissions[${i}].id`).to.have.property('id').that.is.a('string').and.not.empty;",
                  "        pm.expect(p, `permissions[${i}].canonical_name`).to.have.property('canonical_name').that.is.a('string').and.not.empty;",
                  "        pm.expect(p, `permissions[${i}].resource_type`).to.have.property('resource_type').that.is.a('string').and.not.empty;",
                  "        pm.expect(p, `permissions[${i}].name`).to.have.property('name').that.is.a('string').and.not.empty;",
                  "    });",
                  "});",
                  "",
                  "pm.test('rbac:read is present in the list', () => {",
                  "    const found = body.permissions.some(p => p.canonical_name === 'rbac:read');",
                  "    pm.expect(found, 'rbac:read not found in permissions list').to.be.true;",
                  "});",
                  "",
                  "pm.test('each permission has capabilities with scope_policy and access_types', () => {",
                  "    body.permissions.forEach((p, i) => {",
                  "        pm.expect(p, `permissions[${i}].capabilities`).to.have.property('capabilities').that.is.an('object');",
                  "        pm.expect(p.capabilities, `permissions[${i}].capabilities.scope_policy`).to.have.property('scope_policy').that.is.a('string').and.not.empty;",
                  "        pm.expect(p.capabilities, `permissions[${i}].capabilities.access_types`).to.have.property('access_types').that.is.an('array').and.have.length.above(0);",
                  "    });",
                  "});",
                  "",
                  "pm.test('product:manage has scope_policy any and conditional+request in access_types', () => {",
                  "    const p = body.permissions.find(p => p.canonical_name === 'product:manage');",
                  "    if (!p) { console.warn('[WARN] product:manage not found'); return; }",
                  "    pm.expect(p.capabilities.scope_policy).to.eql('any');",
                  "    pm.expect(p.capabilities.access_types).to.include('conditional');",
                  "    pm.expect(p.capabilities.access_types).to.include('request');",
                  "});",
                  "",
                  "pm.test('rbac:read has scope_policy none and only direct+denied', () => {",
                  "    const p = body.permissions.find(p => p.canonical_name === 'rbac:read');",
                  "    if (!p) { console.warn('[WARN] rbac:read not found'); return; }",
                  "    pm.expect(p.capabilities.scope_policy).to.eql('none');",
                  "    pm.expect(p.capabilities.access_types).to.include('direct');",
                  "    pm.expect(p.capabilities.access_types).to.include('denied');",
                  "    pm.expect(p.capabilities.access_types).to.not.include('conditional');",
                  "    pm.expect(p.capabilities.access_types).to.not.include('request');",
                  "});",
                  "",
                  "pm.test('no Set-Cookie header', () => {",
                  "    const sc = pm.response.headers.get('Set-Cookie') || '';",
                  "    pm.expect(sc).to.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{perms_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions"]
            }
          }
        },
        {
          "name": "GET /permissions/groups \u2192 200 \u2014 groups array with embedded members",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Content-Type is application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('top-level key is groups array', () => {",
                  "    pm.expect(body.groups).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('groups list is non-empty (seed data present)', () => {",
                  "    pm.expect(body.groups.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('each group has id, name, display_order, is_visible, members', () => {",
                  "    body.groups.forEach((g, i) => {",
                  "        pm.expect(g, `groups[${i}].id`).to.have.property('id').that.is.a('string').and.not.empty;",
                  "        pm.expect(g, `groups[${i}].name`).to.have.property('name').that.is.a('string').and.not.empty;",
                  "        pm.expect(g, `groups[${i}].display_order`).to.have.property('display_order').that.is.a('number');",
                  "        pm.expect(g, `groups[${i}].is_visible`).to.have.property('is_visible').that.is.a('boolean');",
                  "        pm.expect(g, `groups[${i}].members`).to.have.property('members').that.is.an('array');",
                  "    });",
                  "});",
                  "",
                  "pm.test('each group member has id, canonical_name, resource_type, name', () => {",
                  "    body.groups.forEach((g, gi) => {",
                  "        g.members.forEach((m, mi) => {",
                  "            pm.expect(m, `groups[${gi}].members[${mi}].id`).to.have.property('id').that.is.a('string').and.not.empty;",
                  "            pm.expect(m, `groups[${gi}].members[${mi}].canonical_name`).to.have.property('canonical_name').that.is.a('string').and.not.empty;",
                  "            pm.expect(m, `groups[${gi}].members[${mi}].resource_type`).to.have.property('resource_type').that.is.a('string').and.not.empty;",
                  "            pm.expect(m, `groups[${gi}].members[${mi}].name`).to.have.property('name').that.is.a('string').and.not.empty;",
                  "        });",
                  "    });",
                  "});",
                  "",
                  "pm.test('each group member has capabilities with scope_policy and access_types', () => {",
                  "    body.groups.forEach((g, gi) => {",
                  "        g.members.forEach((m, mi) => {",
                  "            pm.expect(m, `groups[${gi}].members[${mi}].capabilities`).to.have.property('capabilities').that.is.an('object');",
                  "            pm.expect(m.capabilities, `groups[${gi}].members[${mi}].capabilities.scope_policy`).to.have.property('scope_policy').that.is.a('string').and.not.empty;",
                  "            pm.expect(m.capabilities, `groups[${gi}].members[${mi}].capabilities.access_types`).to.have.property('access_types').that.is.an('array').and.have.length.above(0);",
                  "        });",
                  "    });",
                  "});",
                  "",
                  "pm.test('no Set-Cookie header', () => {",
                  "    const sc = pm.response.headers.get('Set-Cookie') || '';",
                  "    pm.expect(sc).to.be.empty;",
                  "});"
