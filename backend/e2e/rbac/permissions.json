                  "pm.test('status is 403', () => pm.response.to.have.status(403));",
                  "pm.test('code is forbidden', () => pm.expect(pm.response.json().code).to.eql('forbidden'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{perms_access_token}}"
              },
              {
                "key": "X-Forwarded-For",
                "value": "{{_xff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/permissions/groups",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "permissions", "groups"]
