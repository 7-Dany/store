      ]
    },
    {
      "name": "owner-bootstrap",
      "item": [
        {
          "name": "POST /owner/bootstrap \u2192 201 (grant owner role to acting user)",
          "event": [
            {"listen": "prerequest", "script": {"type": "text/javascript", "exec": [
              "const token = pm.collectionVariables.get('ur_access_token');",
              "if (!token) { console.error('[ERROR] ur_access_token not set \u2014 setup/POST /login did not complete.'); }",
              "const secret = pm.environment.get('bootstrap_secret');",
              "if (!secret) { console.error('[ERROR] bootstrap_secret not set in environment \u2014 add it to environment.json.'); }"
            ]}},
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "pm.test('role_name is owner', () => pm.expect(pm.response.json().role_name).to.eql('owner'));",
              "console.log('[INFO] Acting user is now owner \u2014 RBAC.Require(rbac:read) and RBAC.Require(rbac:manage) will pass on subsequent requests.');"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ur_access_token}}"}, {"key": "X-Forwarded-For", "value": "{{_xff}}"}],
            "body": {"mode": "raw", "raw": "{\"secret\": \"{{bootstrap_secret}}\"}", "options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/owner/assign", "host": ["{{base_url}}"], "path": ["api","v1","owner","assign"]}
          }
        }
      ]
    },
    {
      "name": "happy-path",
      "item": [
        {
          "name": "GET /rbac/users/{target}/role \u2014 no role yet \u2192 404",
          "event": [
            {"listen": "prerequest", "script": {"type": "text/javascript", "exec": ["const id = pm.collectionVariables.get('ur_target_user_id'); if (!id) { console.error('[ERROR] ur_target_user_id not set \u2014 setup did not complete.'); }"]}},
            {"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('status is 404', () => pm.response.to.have.status(404));", "pm.test('code is user_role_not_found', () => pm.expect(pm.response.json().code).to.eql('user_role_not_found'));"]}}
          ],
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{ur_access_token}}"}, {"key": "X-Forwarded-For", "value": "{{_xff}}"}], "url": {"raw": "{{base_url}}/api/v1/admin/rbac/users/{{ur_target_user_id}}/role", "host": ["{{base_url}}"], "path": ["api","v1","admin","rbac","users","{{ur_target_user_id}}","role"]}}
        },
        {
          "name": "GET /rbac/roles \u2192 200 (capture a non-owner assignable role as ur_role_id)",
          "event": [
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('roles list is non-empty', () => pm.expect(body.roles).to.be.an('array').and.have.length.above(0));",
              "let candidate = body.roles.find(r => !r.is_owner_role && !r.is_system_role);",
