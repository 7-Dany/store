          "name": "DELETE /rbac/users/{user_id}/role \u2014 no Authorization \u2192 401",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('status is 401', () => pm.response.to.have.status(401));", "pm.test('code is missing_token', () => pm.expect(pm.response.json().code).to.eql('missing_token'));"]}}],
          "request": {"method": "DELETE", "header": [{"key": "X-Forwarded-For", "value": "{{_xff}}"}], "url": {"raw": "{{base_url}}/api/v1/admin/rbac/users/00000000-0000-0000-0000-000000000001/role", "host": ["{{base_url}}"], "path": ["api","v1","admin","rbac","users","00000000-0000-0000-0000-000000000001","role"]}}
        }
      ]
    },
    {
      "name": "rbac-guard",
      "item": [
        {
          "name": "GET /rbac/users/{user_id}/role \u2014 valid JWT, no rbac:read \u2192 403",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('status is 403', () => pm.response.to.have.status(403));", "pm.test('code is forbidden', () => pm.expect(pm.response.json().code).to.eql('forbidden'));"]}}],
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{ur_access_token}}"}, {"key": "X-Forwarded-For", "value": "{{_xff}}"}], "url": {"raw": "{{base_url}}/api/v1/admin/rbac/users/00000000-0000-0000-0000-000000000001/role", "host": ["{{base_url}}"], "path": ["api","v1","admin","rbac","users","00000000-0000-0000-0000-000000000001","role"]}}
        },
