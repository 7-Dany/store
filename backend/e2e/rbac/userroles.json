          "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{ur_access_token}}"}, {"key": "X-Forwarded-For", "value": "{{_xff}}"}], "body": {"mode": "raw", "raw": "{\"role_id\": \"00000000-0000-0000-0000-000000000001\", \"granted_reason\": \"test\"}", "options": {"raw": {"language": "json"}}}, "url": {"raw": "{{base_url}}/api/v1/admin/rbac/users/00000000-0000-0000-0000-000000000001/role", "host": ["{{base_url}}"], "path": ["api","v1","admin","rbac","users","00000000-0000-0000-0000-000000000001","role"]}}
        },
        {
          "name": "DELETE /rbac/users/{user_id}/role \u2014 valid JWT, no rbac:manage \u2192 403",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": ["pm.test('status is 403', () => pm.response.to.have.status(403));", "pm.test('code is forbidden', () => pm.expect(pm.response.json().code).to.eql('forbidden'));"]}}],
          "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{ur_access_token}}"}, {"key": "X-Forwarded-For", "value": "{{_xff}}"}], "url": {"raw": "{{base_url}}/api/v1/admin/rbac/users/00000000-0000-0000-0000-000000000001/role", "host": ["{{base_url}}"], "path": ["api","v1","admin","rbac","users","00000000-0000-0000-0000-000000000001","role"]}}
