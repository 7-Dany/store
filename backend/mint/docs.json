{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Store API",
  "colors": {
    "primary": "#FF7819",
    "light": "#FF9038",
    "dark": "#E07820"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "mdx": {
      "server": "http://localhost:8080",
      "auth": {
        "method": "bearer"
      }
    },
    "examples": {
      "prefill": true,
      "languages": ["curl", "c++", "go", "javascript", "python", "php"]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Overview",
            "icon": "book-open",
            "pages": ["guides/overview"]
          },
          {
            "group": "Authentication",
            "icon": "lock",
            "pages": [
              "guides/auth/registration-flow",
              "guides/auth/session-lifecycle",
              "guides/auth/account-unlock-flow",
              "guides/auth/password-reset-flow",
              "guides/auth/google-oauth-flow"
            ]
          },
          {
            "group": "Profile",
            "icon": "user",
            "pages": ["guides/profile/email-change-flow"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "house",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Health",
            "icon": "heart-pulse",
            "pages": ["api-reference/health"]
          },
          {
            "group": "Auth",
            "icon": "lock",
            "pages": [
              "api-reference/auth/register/register",
              "api-reference/auth/verification/verify-email",
              "api-reference/auth/verification/resend-verification",
              "api-reference/auth/login/login",
              "api-reference/auth/session/refresh",
              "api-reference/auth/session/logout",
              "api-reference/auth/unlock/request-unlock",
              "api-reference/auth/unlock/confirm-unlock",
              "api-reference/auth/password/forgot-password",
              "api-reference/auth/password/verify-reset-code",
              "api-reference/auth/password/reset-password",
              "api-reference/auth/password/change-password"
            ]
          },
          {
            "group": "OAuth",
            "icon": "google",
            "pages": [
              "api-reference/oauth/google/initiate",
              "api-reference/oauth/google/callback",
              "api-reference/oauth/google/unlink"
            ]
          },
          {
            "group": "Profile",
            "icon": "user",
            "pages": [
              "api-reference/profile/me/me",
              "api-reference/profile/me/update-profile",
              "api-reference/profile/session/sessions",
              "api-reference/profile/session/revoke-session",
              "api-reference/profile/set-password/set-password",
              "api-reference/profile/username/update-username",
              "api-reference/profile/username/username-available",
              "api-reference/profile/email/request-change",
              "api-reference/profile/email/verify-current",
              "api-reference/profile/email/confirm-change"
            ]
          }
        ]
      }
    ]
  }
}
