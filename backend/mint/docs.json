{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Store API",
  "icons": {
    "library": "tabler"
  },
  "colors": {
    "primary": "#00776F",
    "light": "#00BBA7",
    "dark": "#005F5A"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "mdx": {
      "server": "http://localhost:8080/api/v1",
      "auth": {
        "method": "bearer"
      }
    },
    "examples": {
      "prefill": true,
      "languages": ["curl", "c++", "go", "javascript", "python", "php"]
    }
  },
  "interaction": {
    "drilldown": false
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "tabs": [
      {
