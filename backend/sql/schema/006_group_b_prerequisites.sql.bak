-- +goose NO TRANSACTION
-- 006_group_b_prerequisites.sql — Schema additions required before any Group B route
-- (§B-1 username, §B-2 email change, §B-3 delete account) can be implemented.
--
-- Depends on: 001_core.sql (one_time_tokens, users), 003_rbac.sql (roles)
--
-- Why NO TRANSACTION:
--   ALTER TYPE … ADD VALUE cannot execute inside a transaction block in PostgreSQL < 12.
--   Using NO TRANSACTION makes the whole file safe across all supported PG versions.
--   The IF NOT EXISTS / IF EXISTS guards below make re-running after a partial failure safe.


-- ============================================================
-- Up
-- ============================================================

-- +goose StatementBegin
-- Step 1 — Extend the one_time_token_type enum with the two email-change discriminators.
-- These must run before any table DDL that references the new values.
ALTER TYPE one_time_token_type ADD VALUE IF NOT EXISTS 'email_change_verify';
ALTER TYPE one_time_token_type ADD VALUE IF NOT EXISTS 'email_change_confirm';
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 2 — Add metadata JSONB column to one_time_tokens.
-- email_change_verify tokens store {"new_email": "…"} here so the confirm step
-- knows which address to OTP-verify without a separate KV lookup.
ALTER TABLE one_time_tokens
    ADD COLUMN IF NOT EXISTS metadata JSONB;

COMMENT ON COLUMN one_time_tokens.metadata IS
    'Auxiliary payload for specific token types. '
    'email_change_verify stores {"new_email": "..."} so the confirm step can '
    'retrieve the destination address without a separate KV lookup.';
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 3 — Add deleted_at to users (soft-delete, recommended approach).
--
-- Decision rationale (§B-3 trade-off):
--   Soft-delete is preferred over hard-delete because:
--     • The RBAC audit tables (user_roles_audit, user_permissions_audit,
--       role_permissions_audit) carry ON DELETE RESTRICT FKs to users — a hard
--       DELETE would require manually cleaning audit history first.
--     • A 30-day grace period allows self-service recovery and dispute resolution.
--     • All existing queries are unaffected today; the app layer adds
--       WHERE deleted_at IS NULL to every user lookup as part of §B-3 implementation.
--
-- Partial unique index below preserves the email/username uniqueness guarantee
-- for active accounts while allowing the same address to be re-registered after
-- the grace period expires.
ALTER TABLE users
    ADD COLUMN IF NOT EXISTS deleted_at TIMESTAMPTZ;

COMMENT ON COLUMN users.deleted_at IS
    'NULL = active account. Non-NULL = soft-deleted (grace period applies). '
    'App layer MUST filter WHERE deleted_at IS NULL on all user reads/writes. '
    'Cleared by account recovery; hard-purged by background job after grace period.';

-- Preserve uniqueness for active users only.
-- Existing idx_users_email / idx_users_username cover all rows (including deleted);
-- these partial indexes override that for the application-visible uniqueness check.
CREATE UNIQUE INDEX IF NOT EXISTS idx_users_email_active
    ON users (email)
    WHERE email IS NOT NULL AND deleted_at IS NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_users_username_active
    ON users (username)
    WHERE username IS NOT NULL AND deleted_at IS NULL;
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 4 — Relax chk_ott_magic_link_requires_token_hash to include the new OTP-only types.
--
-- Original constraint: if token_type is NOT in (ev, au, pr) then token_hash MUST be set.
-- The two new types are OTP-only (code_hash), so they must be added to the exclusion list.
ALTER TABLE one_time_tokens
    DROP CONSTRAINT IF EXISTS chk_ott_magic_link_requires_token_hash;

ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_magic_link_requires_token_hash
        CHECK (
            token_type IN (
                'email_verification',
                'account_unlock',
                'password_reset',
                'email_change_verify',
                'email_change_confirm'
            )
            OR token_hash IS NOT NULL
        );
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 5 — Expand chk_ott_otp_fields_scoped to permit code_hash on the new types.
--
-- Original constraint: code_hash may only be non-NULL for (ev, au, pr).
-- Both new types are OTP-based and need code_hash.
ALTER TABLE one_time_tokens
    DROP CONSTRAINT IF EXISTS chk_ott_otp_fields_scoped;

ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_otp_fields_scoped
        CHECK (
            code_hash IS NULL
            OR token_type IN (
                'email_verification',
                'account_unlock',
                'password_reset',
                'email_change_verify',
                'email_change_confirm'
            )
        );
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 6 — Hard TTL cap: email_change_verify tokens expire within 15 minutes.
-- Matches the chk_ott_ev_ttl_max / chk_ott_au_ttl_max naming pattern.
ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_ecv_ttl_max
        CHECK (
            token_type != 'email_change_verify'
            OR expires_at <= created_at + INTERVAL '15 minutes'
        );

-- Step 7 — Hard TTL cap: email_change_confirm tokens expire within 15 minutes.
ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_ecc_ttl_max
        CHECK (
            token_type != 'email_change_confirm'
            OR expires_at <= created_at + INTERVAL '15 minutes'
        );
-- +goose StatementEnd


-- +goose StatementBegin
-- Step 8 — Prevent concurrent email-change requests for the same user.
-- Matches the idx_password_reset_tokens_user_active pattern exactly.
-- Application layer catches the 23505 violation and returns ErrEmailChangeCooldown.
CREATE UNIQUE INDEX IF NOT EXISTS idx_email_change_verify_tokens_user_active
    ON one_time_tokens (user_id)
    WHERE token_type = 'email_change_verify' AND used_at IS NULL;

-- Step 9 — Prevent two simultaneous confirm tokens for the same user.
CREATE UNIQUE INDEX IF NOT EXISTS idx_email_change_confirm_tokens_user_active
    ON one_time_tokens (user_id)
    WHERE token_type = 'email_change_confirm' AND used_at IS NULL;
-- +goose StatementEnd


-- ============================================================
-- Down
-- ============================================================

-- +goose StatementBegin
-- Remove unique indexes added in steps 8-9.
DROP INDEX IF EXISTS idx_email_change_confirm_tokens_user_active;
DROP INDEX IF EXISTS idx_email_change_verify_tokens_user_active;
-- +goose StatementEnd

-- +goose StatementBegin
-- Remove TTL cap constraints added in steps 6-7.
ALTER TABLE one_time_tokens DROP CONSTRAINT IF EXISTS chk_ott_ecc_ttl_max;
ALTER TABLE one_time_tokens DROP CONSTRAINT IF EXISTS chk_ott_ecv_ttl_max;
-- +goose StatementEnd

-- +goose StatementBegin
-- Restore chk_ott_otp_fields_scoped to its original three-type form.
ALTER TABLE one_time_tokens DROP CONSTRAINT IF EXISTS chk_ott_otp_fields_scoped;
ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_otp_fields_scoped
        CHECK (
            code_hash IS NULL
            OR token_type IN ('email_verification', 'account_unlock', 'password_reset')
        );
-- +goose StatementEnd

-- +goose StatementBegin
-- Restore chk_ott_magic_link_requires_token_hash to its original three-type form.
ALTER TABLE one_time_tokens DROP CONSTRAINT IF EXISTS chk_ott_magic_link_requires_token_hash;
ALTER TABLE one_time_tokens
    ADD CONSTRAINT chk_ott_magic_link_requires_token_hash
        CHECK (
            token_type IN ('email_verification', 'account_unlock', 'password_reset')
            OR token_hash IS NOT NULL
        );
-- +goose StatementEnd

-- +goose StatementBegin
-- Remove soft-delete indexes and column.
DROP INDEX IF EXISTS idx_users_username_active;
DROP INDEX IF EXISTS idx_users_email_active;
ALTER TABLE users DROP COLUMN IF EXISTS deleted_at;
-- +goose StatementEnd

-- +goose StatementBegin
-- Remove metadata column.
ALTER TABLE one_time_tokens DROP COLUMN IF EXISTS metadata;
-- +goose StatementEnd

-- NOTE: ALTER TYPE … ADD VALUE cannot be rolled back in PostgreSQL.
-- 'email_change_verify' and 'email_change_confirm' will remain in the
-- one_time_token_type enum after a Down migration. This is safe — no rows
-- will reference them once the table changes above are reverted.
